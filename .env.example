# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=policy_kb_l0

# Embedding model
EMBED_MODEL=BAAI/bge-large-zh-v1.5

# L2+ (Tickets/Audit DB)
DATABASE_URL=postgresql+psycopg2://policy:policy@localhost:5432/policy_kb
REDIS_URL=redis://localhost:6379/0
AUTO_MIGRATE_ON_STARTUP=true
DEV_DB_FALLBACK_CREATE_ALL=false
POLICY_API_BASE_URL=http://localhost:8080
POLICY_API_KEY=YOUR_POLICY_API_KEY
TICKET_DRAFT_TTL_MINUTES=20

# LLM (DeepSeek OpenAI-compatible)
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=deepseek-chat
OPENAI_FALLBACK_MODEL=deepseek-chat
OPENAI_TIMEOUT_SECONDS=30
